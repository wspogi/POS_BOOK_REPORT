SQL_SERVER=192.168.xxx.xxx
SQL_DATABASE=VQPBOS
SQL_USERNAME=your_username
SQL_PASSWORD=your_password_here

POS_BRANCH=CAM

# DATE_MODE options:
# PREVIOUS_MONTH = automatic previous month
# CUSTOM = use DATE_FROM and DATE_TO
DATE_MODE=PREVIOUS_MONTH

# Use only when DATE_MODE=CUSTOM
# DATE_FROM=2026-04-01
# DATE_TO=2026-04-30

TEMPLATE_FILE=templates/APR.xlsx

OUTPUT_DIR=output
LOG_DIR=logs